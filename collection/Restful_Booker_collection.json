            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// CreateBooking - Validate response and extract bookingId variable",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has bookingid and booking fields\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"bookingid\");",
                  "    pm.expect(jsonData).to.have.property(\"booking\");",
                  "    pm.expect(jsonData.bookingid).to.be.a(\"number\");",
                  "});",
                  "",
                  "pm.test(\"Booking object has required fields\", function () {",
                  "    const booking = pm.response.json().booking;",
                  "    pm.expect(booking).to.have.property(\"firstname\");",
                  "    pm.expect(booking).to.have.property(\"lastname\");",
                  "    pm.expect(booking).to.have.property(\"totalprice\");",
                  "    pm.expect(booking).to.have.property(\"depositpaid\");",
                  "    pm.expect(booking).to.have.property(\"bookingdates\");",
                  "    pm.expect(booking).to.have.property(\"additionalneeds\");",
                  "});",
                  "",
                  "pm.test(\"Booking field types are correct\", function () {",
                  "    const booking = pm.response.json().booking;",
                  "    pm.expect(booking.firstname).to.be.a(\"string\");",
                  "    pm.expect(booking.lastname).to.be.a(\"string\");",
                  "    pm.expect(booking.totalprice).to.be.a(\"number\");",
                  "    pm.expect(booking.depositpaid).to.be.a(\"boolean\");",
                  "    pm.expect(booking.bookingdates).to.be.an(\"object\");",
                  "    pm.expect(booking.bookingdates).to.have.property(\"checkin\");",
                  "    pm.expect(booking.bookingdates).to.have.property(\"checkout\");",
                  "});",
                  "",
                  "pm.test(\"Booking dates are present\", function () {",
                  "    const bookingdates = pm.response.json().booking.bookingdates;",
                  "    pm.expect(bookingdates.checkin).to.be.a(\"string\").and.not.empty;",
                  "    pm.expect(bookingdates.checkout).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "",
                  "pm.test(\"Response time is acceptable\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});",
                  "",
                  "// Extract bookingId for use in subsequent requests",
                  "const jsonData = pm.response.json();",
                  "if (jsonData && jsonData.bookingid) {",
                  "    pm.environment.set(\"bookingId\", jsonData.bookingid);",
                  "    console.log(\"bookingId set to: \" + jsonData.bookingid);",
                  "}",
                  ""
                ]
